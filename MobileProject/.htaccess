# ✅ Security Headers
<IfModule mod_headers.c>
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
  Header always set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(self), microphone=()"
  Header set X-XSS-Protection "1; mode=block"
  Header set Content-Security-Policy "default-src 'self' https:; script-src 'self' https: 'unsafe-inline'; style-src 'self' https: 'unsafe-inline'; img-src 'self' https: data:;"
</IfModule>


<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresDefault "access plus 2 days"
</IfModule>



# Enable rewrite engine
RewriteEngine On
RewriteBase /

# --- Security folders exclude ---
RewriteCond %{REQUEST_URI} ^/(phpmyadmin|xampp|server-status) [NC]
RewriteRule ^ - [L]

# --- If file or folder exists, do nothing ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 404 পেজ কাস্টম হ্যান্ডেল
ErrorDocument 404 /404.html

# Redirect only index.php to /
RewriteCond %{THE_REQUEST} \s/index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]


# --- SEO friendly routes ---

# brands/BrandName → brands.php?brand=BrandName
RewriteRule ^brands/([^/]+)/?$ brands.php?brand=$1 [L,QSA]

# top-phones/Query → top-phones.php?name=Query
RewriteRule ^top-phones/(.+)$ top-phones.php?name=$1 [L,QSA]

# top10/Query → top10.php?slug=Query
RewriteRule ^top10/(.+)$ top10.php?slug=$1 [L,QSA]

# camera-phones/Query → camera-phones.php?slug=Query
RewriteRule ^camera-phones/(.+)$ camera-phones.php?slug=$1 [L,QSA]

# gaming-phones/Query → gaming-phones.php?slug=Query
RewriteRule ^gaming-phones/(.+)$ gaming-phones.php?slug=$1 [L,QSA]

# phone-details/Query → phone-details.php?name=Query
RewriteRule ^phone-details/(.+)$ phone-details.php?name=$1 [L,QSA]

# user-gied/Query → user-gied.php?name=Query
RewriteRule ^user-gied/(.+)$ user-gied.php?name=$1 [L,QSA]

# user-gied-details/Query → user-gied-details.php?name=Query
RewriteRule ^user-gied-details/(.+)$ user-gied-details.php?name=$1 [L,QSA]

# sitemap.xml → sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# --- Default page rewrite ---
# /about → about.php (যদি admin ফোল্ডারে না থাকে)
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.php [L,QSA]
